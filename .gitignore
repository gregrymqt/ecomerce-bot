# .python-version

# pipenv
#   According to pypa/pipenv#598, it is recommended to include Pipfile.lock in version control.
#   However, in some repositories, pipenv leaves a Pipfile.lock.backup; feel free to convert to
#   comment if needed.
# Pipfile.lock

# poetry
#   Base poetry files, including dependencies, should be committed to version control
# poetry.lock

