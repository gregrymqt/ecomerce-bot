# Configurações do Banco de Dados PostgreSQL (Supabase ou Local)
POSTGRES_URI=postgresql+asyncpg://postgres:postgres@localhost:5432/ecommerce_bot_db

# Mensageria RabbitMQ
RABBITMQ_URL=amqp://guest:guest@localhost:5672/

# Cache & Streaming SSE (Redis)
REDIS_URL=redis://localhost:6379/0
REDIS_PASSWORD=

# Criptografia BYOK (AES-256 GCM)
# Chave mestra em Base64 (32 bytes decodificados para cifrar chaves de tenants)
AES_MASTER_KEY=

# Autenticação JWT
JWT_SECRET_KEY=sua_chave_secreta_jwt_aqui

# Provedores de Inteligência Artificial (Fallback Global)
DEEPSEEK_API_KEY=
GROQ_API_KEY=
OPENAI_API_KEY=
GEMINI_API_KEY=

# Notificações e Webhooks
DISCORD_WEBHOOK_URL=
